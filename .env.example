CLOUDFLARE_ACCOUNT_ID=your-account-id
CLOUDFLARE_AUTH_TOKEN=your-auth-token-from-cloudflare-dashboard
# Try: @cf/black-forest-labs/flux-2-klein-9b (image gen) or google/nano-banana-2-lite
CLOUDFLARE_MODEL=@cf/black-forest-labs/flux-2-klein-9b

# Output canvas dimensions (default)
CANVAS_WIDTH=1400
CANVAS_HEIGHT=1400